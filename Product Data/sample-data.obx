      <description type='short' default='0'>
	<text lang='de'>Aeron Stuhl</text>
	<text lang='en'>Aeron Chair</text>
	<text lang='fr'>Siège haut Aeron</text>
	<text lang='nl'>Aeron-stoel</text>
